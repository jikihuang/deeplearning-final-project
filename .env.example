# Boson TTS
BOSON_API_KEY=your_boson_api_key_here
BOSON_VOICE=default

# Qwen vLLM
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=local-qwen
LLM_MODEL=qwen2.5-7b-instruct

# MuseTalk
MUSETALK_DIR=/workspace/MuseTalk
MUSETALK_CUDA_VISIBLE_DEVICES=1
MUSETALK_WORKER_URL=http://127.0.0.1:8890
MUSETALK_WORKER_PORT=8890

# Gradio
GRADIO_SERVER_PORT=8888

# Optional idle/thinking videos
IDLE_VIDEO=/workspace/digital_human_demo/assets/idle.mp4
THINKING_VIDEO=/workspace/digital_human_demo/assets/thinking.mp4

# Optional default motion video
TEST2_DIR=/workspace/digital_human_demo/data/test2
DEFAULT_MOTION_VIDEO=/workspace/digital_human_demo/data/test2/avatar--test2_25fps.mp4
